{
  "expo": {
    "name": "Toned",
    "slug": "Toned",
    "scheme": "toned",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "newArchEnabled": true,
    "backgroundColor": "#080808",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mzsean.Toned"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#080808"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.mzsean.Toned"
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c71a89b9-fef3-43a7-9e22-189e5dce73dd"
      }
    }
  }
}
