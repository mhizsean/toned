{
  "name": "toned",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "CI=1 expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watch",
    "postinstall": "bash scripts/patch-expo-constants.sh",
    "e2e": "MAESTRO_DRIVER_STARTUP_TIMEOUT=300000 JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home $HOME/.maestro/bin/maestro test --device \"iPhone 17 Pro\" .maestro/e2e-suite.yml",
    "e2e:smoke": "MAESTRO_DRIVER_STARTUP_TIMEOUT=300000 JAVA_HOME=/opt/homebrew/opt/openjdk@17/libexec/openjdk.jdk/Contents/Home $HOME/.maestro/bin/maestro test --device \"iPhone 17 Pro\" .maestro/smoke.yml"
  },
  "dependencies": {
    "@expo-google-fonts/bebas-neue": "^0.4.1",
    "@expo-google-fonts/dm-sans": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/jest": "29.5.14",
    "expo": "~54.0.34",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "^0.21.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/react": "~19.1.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
